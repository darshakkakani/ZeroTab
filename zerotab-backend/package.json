{
  "name": "zerotab-backend",
  "version": "1.0.0",
  "description": "ZeroTab — AI-powered personal finance tracker backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --forceExit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@supabase/supabase-js": "^2.43.4",
    "@upstash/redis": "^1.31.3",
    "axios": "^1.7.2",
    "bullmq": "^5.7.10",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.27.0",
    "google-auth-library": "^9.11.0",
    "pdf-parse": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "xirr": "^1.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/pdf-parse": "^1.1.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "node"
          }
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
